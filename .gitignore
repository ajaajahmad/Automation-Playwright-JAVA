# =========================
# Maven / Java
# =========================
target/
*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar

# Maven wrapper / build metadata
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties

# Maven timing / cache
.mvn/timing.properties

# Keep Maven wrapper JAR if your team uses wrapper
# Remove this ignore if you want to commit it
.mvn/wrapper/maven-wrapper.jar
.mvn

# Logs
logs/
*.log

# JVM crash logs
hs_err_pid*
replay_pid*

